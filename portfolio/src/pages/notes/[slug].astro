---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map(note => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title={note.data.title}
  description={note.data.description}
  ogType="article"
  publishedDate={note.data.date.toISOString()}
>
  <div class="container">

    <a href="/notes" class="back-link">← Notes</a>

    <article>
      <header class="post-header">
        <div class="post-meta">
          <time datetime={note.data.date.toISOString()}>{formatDate(note.data.date)}</time>
          {note.data.tags?.map(t => <span class="tag">{t}</span>)}
        </div>
        <h1 class="post-title">{note.data.title}</h1>
        {note.data.description && <p class="post-lead">{note.data.description}</p>}
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>

  </div>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.8125rem;
    color: var(--text-3);
    margin-bottom: 3rem;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--text); }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
    font-size: 0.775rem;
    color: var(--text-3);
  }

  .post-title {
    font-size: clamp(1.875rem, 4.5vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .post-lead {
    font-size: 1.0625rem;
    color: var(--text-2);
    max-width: 52ch;
    line-height: 1.7;
  }
</style>
